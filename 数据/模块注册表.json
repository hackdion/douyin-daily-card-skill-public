{
  "说明": "模块是封面和底图的积木块。状态为 stable 的模块才允许被默认模板自动调用。",
  "modules": [
    {
      "id": "canvas-1080x1440-safe-area",
      "中文名": "1080x1440安全画布",
      "类型": "画布模块",
      "状态": "stable",
      "用途": ["封面", "底图", "正文页"],
      "默认参数": {
        "width": 1080,
        "height": 1440,
        "safeMargin": 80
      },
      "依赖素材": []
    },
    {
      "id": "text-account-date-id-basic",
      "中文名": "账号日期ID基础信息组",
      "类型": "信息模块",
      "状态": "stable",
      "用途": ["封面", "底图"],
      "默认参数": {
        "accountPosition": "left-top",
        "idPosition": "right-bottom",
        "datePosition": "center-lower"
      },
      "依赖素材": []
    },
    {
      "id": "public-demo-silhouette-character",
      "中文名": "公开演示剪影角色",
      "类型": "角色模块",
      "状态": "beta",
      "用途": ["封面", "底图"],
      "默认参数": {
        "position": "right-bottom",
        "opacity": 0.82,
        "allowReplace": true
      },
      "依赖素材": ["CSS生成或公开剪影素材"]
    },
    {
      "id": "interactive-text-slider-controls",
