        "importJson": true
      },
      "依赖素材": []
    },
    {
      "id": "public-safe-css-mascot",
      "中文名": "公开安全CSS抽象吉祥物",
      "类型": "角色模块",
      "状态": "beta",
      "用途": ["封面", "底图", "公开演示"],
      "默认参数": {
        "variants": ["robot", "star", "sprite"],
